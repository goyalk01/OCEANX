<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme using Material Design 3 -->
    <style name="Theme.FreshCart" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary color (main brand color) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        
        <!-- On Primary (text/icons on primary color) -->
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary color (accents) -->
        <item name="colorSecondary">@color/success</item>
        <item name="colorSecondaryVariant">@color/success</item>
        <item name="colorOnSecondary">@color/on_primary</item>

        <!-- Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_primary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text Appearances -->
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.FreshCart.HeadlineMedium</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.FreshCart.TitleMedium</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.FreshCart.BodyMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.FreshCart.LabelSmall</item>

        <!-- Button Style -->
        <item name="materialButtonOutlinedStyle">@style/Widget.FreshCart.OutlinedButton</item>
    </style>

    <!-- Text Appearance Styles -->
    <style name="TextAppearance.FreshCart.HeadlineMedium">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FreshCart.TitleMedium">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FreshCart.BodyMedium">
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.FreshCart.LabelSmall">
        <item name="android:textSize">@dimen/text_size_sm</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="Widget.FreshCart.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.FreshCart.AppBarLayout" parent="Widget.Material3.AppBarLayout.Primary">
        <item name="android:background">@color/primary</item>
        <item name="elevation">4dp</item>
    </style>
</resources>
