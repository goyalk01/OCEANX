<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md"
    android:background="@color/surface">

    <!-- Product Image -->
    <ImageView
        android:id="@+id/cartItemImage"
        android:layout_width="@dimen/image_medium"
        android:layout_height="@dimen/image_medium"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="@string/home_popular_products"
        android:scaleType="centerCrop"
        android:layout_marginEnd="@dimen/spacing_md" />

    <!-- Product Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cartItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_md"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/cartItemUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_sm"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm">

            <!-- Quantity Controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cartQuantityMinus"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="@dimen/image_small"
                    android:layout_height="@dimen/image_small"
                    android:text="−"
                    android:minWidth="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <TextView
                    android:id="@+id/cartItemQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:minWidth="@dimen/icon_medium"
                    android:gravity="center" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cartQuantityPlus"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="@dimen/image_small"
                    android:layout_height="@dimen/image_small"
                    android:text="+"
                    android:minWidth="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- Price -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/cartItemPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_sm"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/cartItemTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_lg"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Remove Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/cartRemoveButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="@dimen/image_small"
        android:layout_height="@dimen/image_small"
        android:layout_gravity="top"
        android:text="✕"
        android:textColor="@color/error"
        android:minWidth="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:rippleColor="@color/error" />

</LinearLayout>
